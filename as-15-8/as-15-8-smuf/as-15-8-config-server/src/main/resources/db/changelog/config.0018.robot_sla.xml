            </column>
            <column name="sla_type" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="robot_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
