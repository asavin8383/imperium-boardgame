<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet id="config.0008" author="asavin">
        <createTable schemaName="config" tableName="processing_times">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="processing_timesPK"/>
            </column>
            <column name="robot_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="check_method" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="processing_time" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableSchemaName="config"
                baseTableName="processing_times"
                baseColumnNames="robot_id"
                constraintName="robots_processing_times_id_FK"
                referencedTableSchemaName="config"
                referencedTableName="robots"
                referencedColumnNames="id"/>
    </changeSet>
    <changeSet id="config.0008_1" author="asavin">
        <sql>
            alter table config.processing_times drop constraint if exists ck_check_method;
            alter table config.processing_times add constraint ck_check_method check (check_method in ('browser','nmap'));
        </sql>
        <rollback>
            <sql>
                alter table config.processing_times drop constraint if exists ck_check_method;
            </sql>
        </rollback>
    </changeSet>
</databaseChangeLog>