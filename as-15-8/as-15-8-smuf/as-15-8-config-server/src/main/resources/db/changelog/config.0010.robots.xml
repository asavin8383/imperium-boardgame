<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet id="config.0010.1" author="asin">
        <addColumn schemaName="config" tableName="robots">
            <column name="type" type="varchar">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="config.0010.2" author="asin">
        <sql>
            update config.robots set type='PS' where access_tool='search-system' or orig_name='Yandex' or orig_name='Mail.RU';
            update config.robots set type='PASD' where type is null;
        </sql>
    </changeSet>
    <changeSet id="config.0010.3" author="asin">
        <addNotNullConstraint schemaName="config" tableName="robots" columnName="type"/>
    </changeSet>
    <changeSet id="config.0010.4" author="asin">
        <addUniqueConstraint schemaName="config" tableName="robots" columnNames="orig_id,type" constraintName="orig_id__type_unq"/>
    </changeSet>
</databaseChangeLog>
