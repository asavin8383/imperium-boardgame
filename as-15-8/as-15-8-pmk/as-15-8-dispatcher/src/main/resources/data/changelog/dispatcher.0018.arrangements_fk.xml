<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="asavin" id="0018">
        <sql>
            alter table results.arrangements add constraint ck_status check ( status in ('RUNNING', 'FINISHED'));
            insert into results.arrangements (select arrangement_id, count(*), 'FINISHED' as status from results.results group by arrangement_id);
        </sql>
        <addForeignKeyConstraint
                baseTableSchemaName="results"
                baseTableName="results"
                baseColumnNames="arrangement_id"
                constraintName="FK_arrangements"
                referencedTableSchemaName="results"
                referencedTableName="arrangements"
                referencedColumnNames="id"
                onDelete="CASCADE"
                onUpdate="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableSchemaName="results" baseTableName="results" constraintName="FK_arrangements"/>
        </rollback>
    </changeSet>

</databaseChangeLog>