<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="ashabalin" id="0022.1">
        <addUniqueConstraint tableName="results" columnNames="job_id" schemaName="results"/>
    </changeSet>
    <changeSet author="ashabalin" id="0022.2">
        <addColumn tableName="error_detail_results" schemaName="results">
            <column name="job_id" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="nmap_detail_results" schemaName="results">
            <column name="job_id" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="pasd_detail_results" schemaName="results">
            <column name="job_id" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="ps_detail_results" schemaName="results">
            <column name="job_id" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="result_screenshots" schemaName="results">
            <column name="job_id" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet author="ashabalin" id="0022.3">
        <sql>
            update results.error_detail_results edr set job_id = (
                select max(job_id)
                from results.results r
                where r.id = edr.result_id
            );
        </sql>
        <sql>
            update results.nmap_detail_results ndr set job_id = (
                select max(job_id)
                from results.results r
                where r.id = ndr.result_id
            );
        </sql>
        <sql>
            update results.pasd_detail_results pdr set job_id = (
                select max(job_id)
                from results.results r
                where r.id = pdr.result_id
            );
        </sql>
        <sql>
            update results.ps_detail_results psdr set job_id = (
                select max(job_id)
                from results.results r
                where r.id = psdr.result_id
            );
        </sql>
        <sql>
            update results.result_screenshots sdr set job_id = (
                select max(job_id)
                from results.results r
                where r.id = sdr.result_id
            );
        </sql>
    </changeSet>
</databaseChangeLog>
