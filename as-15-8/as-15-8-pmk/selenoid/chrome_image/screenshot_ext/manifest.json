{
   "background": {
      "persistent": true,
      "scripts": [ "javascript/background.js" ]
   },
   "content_scripts": [ {
      "matches": ["<all_urls>"],
      "js": [ "javascript/content.js"],
      "all_frames": true,
      "run_at": "document_start"
   } ],
   "converted_from_user_script": true,
   "description": "Take a desktop screenshot for AS 15.8",
   "manifest_version": 2,
   "name": "Screenshot by AS 15.8",
   "permissions": [ "activeTab", "background", "desktopCapture"],
   "short_name": "Screenshot by AS 15.8",
   "version": "1.0",
   "web_accessible_resources": [ "javascript/*"]
}
