<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd
    http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">


    <changeSet id="uploader.0011" author="pvorobiev">
        <createTable tableName="mission" schemaName="sor">
            <column name="id" type="bigint" autoIncrement="true" remarks="Уникальный идентификатор">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="orig_id" type="varchar(50)" remarks="Оригинальный идентификатор задания">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="doc_num" type="varchar(50)" remarks="Строковый идентификатор задания">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="type_check" type="integer" remarks="Тип проверки, 1-разовая, 2-периодическая">
                <constraints nullable="false"/>
            </column>
            <column name="doc_file_data" type="bytea" remarks="Документ (PDF) с содержанием задания">
                <constraints nullable="true"/>
            </column>
            <column name="date_approved" type="timestamp" remarks="Дата-время утверждения задания Роскомнадзором">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>