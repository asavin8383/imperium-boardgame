<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="0008.1" author="asin">
        <addColumn schemaName="dm" tableName="reg_reports">
            <column name="rptdesign" type="varchar">
                <constraints nullable="true"/>
            </column>
            <column name="format" type="varchar">
                <constraints nullable="true"/>
            </column>
            <column name="reason" type="varchar">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="0008.2" author="asin">
        <sql>
            update dm.reg_reports set format = mime;
            update dm.reg_reports set rptdesign = case rep_tp_id
                when 1 then 'mis_report_1'
                when 2 then 'mis_report_2'
                when 3 then 'mis_report_3'
            end;
        </sql>
        <rollback>
            <sql>
                update dm.reg_reports set format = null;
                update dm.reg_reports set rptdesign = null;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0008.3" author="asin">
        <addNotNullConstraint schemaName="dm" tableName="reg_reports" columnName="format"/>
        <addNotNullConstraint schemaName="dm" tableName="reg_reports" columnName="rptdesign"/>
    </changeSet>

    <changeSet id="0008.4" author="asin">
        <sql>
            update dm.reg_reports set mime = null;
        </sql>
    </changeSet>

</databaseChangeLog>

