<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">



<changeSet id="0016.1" author="klychagin">
<createTable schemaName="dm" tableName="param_reports">
    <column name="rep_id" type="bigserial"/>
    <column name="rep_tp_id"        type="smallint"/>
    <column name="rep_nm"           type="text"/>
    <column name="msr_prd_id"       type="integer"/>
    <column name="msr_prd_st_dttm"  type="timestamp"/>
    <column name="msr_prd_end_dttm" type="timestamp"/>
    <column name="msr_prd_tp"       type="text"/>
    <column name="msr_prd_tp_id" type="smallint"/>
    <column name="msr_prd_caption"  type="text"/>
    <column name="mime"             type="text"/>
    <column name="data"             type="bytea"/>
    <column name="ppn_dttm"         type="timestamp" defaultValueComputed="now()"/>
    <column name="rptdesign"        type="varchar">
        <constraints nullable="false"/>
    </column>
   <column name="format"           type="varchar">
    <constraints nullable="false"/>
    </column>
</createTable>
</changeSet>
<changeSet id="0016.2" author="klychagin">
<addColumn schemaName="dm" tableName="param_reports">
    <column name="params" type="jsonb"/>
    <column name="username" type="text"/>
</addColumn>
</changeSet>
    <changeSet id="0016.3" author="klychagin">
        <sqlFile encoding="UTF-8" splitStatements="false" path="data/sql/dm_set_msr_prd.sql"/>
        <rollback>
            <sql>
                drop function dm.set_msr_prd();
            </sql>
        </rollback>
    </changeSet>
    <changeSet id="0016.4" author="klychagin">
        <sql>
            CREATE TRIGGER set_msr_prd_params
    AFTER INSERT ON dm.param_reports
    FOR EACH ROW
        EXECUTE PROCEDURE dm.set_msr_prd();
        </sql>
        <rollback>
            <sql>
                DROP TRIGGER  set_msr_prd_params on dm.param_reports;
            </sql>

        </rollback>
    </changeSet>
    <changeSet id="0016.5" author="klychagin">
       <createView viewName="v_api_param_reports_stat" schemaName="dm" replaceIfExists="true">
                select
                     rep_tp.rep_tp_id as row_id,
                     rep_tp.rep_tp_id ,
                     rep_tp.af_id || ' ' || rep_tp.shrt_nm as label,
                     coalesce(d.cnt,0) cnt
                from
                     dm.rep_tp left join
                       (select
                             rep_tp_id, count(*) cnt from dm.param_reports group by  rep_tp_id) d
                  on rep_tp.rep_tp_id=d.rep_tp_id
                where rep_tp.type='PARAM'
                order by  row_id
        </createView>
    </changeSet>
</databaseChangeLog>


