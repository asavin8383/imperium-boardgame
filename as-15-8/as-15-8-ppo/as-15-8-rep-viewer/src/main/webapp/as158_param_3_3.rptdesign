            <method name="beforeOpen"><![CDATA[if (params["IRTZ_CHCK_RSLT"].value!="ALL") {
this.queryText=this.queryText + " and r.result='"+params["IRTZ_CHCK_RSLT"].value+"'"
}

if (params["IRTZ_TRF_W"].value!=null) {
this.queryText=this.queryText + " and addon.visitors_cnt_world>="+params["IRTZ_TRF_W"].value
}

if (params["IRTZ_TRF_RU"].value!=null) {
this.queryText=this.queryText + " and addon.visitors_cnt_russia>="+params["IRTZ_TRF_RU"].value
}

if (params["IRTZ_REG_TS"].value!=null) {
this.queryText=this.queryText + " and ci.includetime::date='"+params["IRTZ_REG_TS"].value+"'"
}

if (params["IRTZ_BLOCKTYPE"].value!="ALL") {
this.queryText=this.queryText + " and coalesce(ci.blocktype,'default')='"+params["IRTZ_BLOCKTYPE"].value+"'"
}

if (params["IRTZ_IRZTYPE"].value!="0") {
this.queryText=this.queryText + " and addon.info_type_id='"+params["IRTZ_IRZTYPE"].value+"'"
}

if (params["IRTZ_REGTYPE"].value!="0") {
this.queryText=this.queryText + " and  addon.orig_id='"+params["IRTZ_REGTYPE"].value+"'"
}

if (params["EVi"].value!=null) {
this.queryText=this.queryText + " and a.id = ANY('{"+params["EVi"].value+"}'::bigint[])"
}

if (params["SSi"].value[0]!=0) {
	queryStr="";
	for (var index = 0; index < params["SSi"].value.length; index++) {
		queryStr = queryStr.concat(params["SSi"].value[index] + ",")
		}
	queryStr = queryStr.substr(0, queryStr.length - 1);

	this.queryText=this.queryText + " and at.orig_id = ANY('{"+queryStr+"}'::bigint[])";
}

this.queryText = this.queryText + " order by at.nm "]]></method>
