            <method name="beforeOpen"><![CDATA[if (params["IRTZ_CHCK_RSLT"].value!="ALL") {
this.queryText=this.queryText + " and r.result='"+params["IRTZ_CHCK_RSLT"].value+"'"
}

if (params["IRTZ_TRF_W"].value!=null) {
this.queryText=this.queryText + " and addon.visitors_cnt_world>="+params["IRTZ_TRF_W"].value
}

if (params["IRTZ_TRF_RU"].value!=null) {
this.queryText=this.queryText + " and addon.visitors_cnt_russia>="+params["IRTZ_TRF_RU"].value
}

if (params["IRTZ_REG_TS"].value!=null) {
this.queryText=this.queryText + " and ci.includetime::date='"+params["IRTZ_REG_TS"].value+"'"
}

if (params["IRTZ_BLOCKTYPE"].value!="ALL") {
this.queryText=this.queryText + " and coalesce(ci.blocktype,'default')='"+params["IRTZ_BLOCKTYPE"].value+"'"
}

if (params["IRTZ_IRZTYPE"].value!="0") {
this.queryText=this.queryText + " and addon.info_type_id='"+params["IRTZ_IRZTYPE"].value+"'"
}

if (params["IRTZ_REGTYPE"].value!="0") {
this.queryText=this.queryText + " and  addon.orig_id='"+params["IRTZ_REGTYPE"].value+"'"
}

if (params["EVi"].value!=null) {
this.queryText=this.queryText + " and a.id = ANY('{"+params["EVi"].value+"}'::bigint[])"
}

if (params["SSi"].value[0]!=0) {
	queryStr="";
	for (var index = 0; index < params["SSi"].value.length; index++) {
		queryStr = queryStr.concat(params["SSi"].value[index] + ",")
		}
	queryStr = queryStr.substr(0, queryStr.length - 1);

	this.queryText=this.queryText + " and at.orig_id = ANY('{"+queryStr+"}'::bigint[])";
}

this.queryText = this.queryText + " group by  at.nm order by at.nm";]]></method>
            <property name="dataSource">asdb</property>
            <list-property name="resultSet">
                <structure>
                    <property name="position">1</property>
                    <property name="name">rn</property>
                    <property name="nativeName">rn</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">2</property>
                    <property name="name">access_tool_name</property>
                    <property name="nativeName">access_tool_name</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">3</property>
                    <property name="name">irtz_chck_ss_all</property>
                    <property name="nativeName">irtz_chck_ss_all</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">4</property>
                    <property name="name">irtz_ss_all</property>
                    <property name="nativeName">irtz_ss_all</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">5</property>
                    <property name="name">irtz_ss_off_all</property>
                    <property name="nativeName">irtz_ss_off_all</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[select
       row_number() over (order by at.nm) rn,
       at.nm as access_tool_name,
       count(distinct r.id) IRTZ_CHCK_SS_ALL,
       count(distinct r.check_unit_value) IRTZ_SS_ALL,
       count(distinct r.check_unit_value) filter ( where last_r.result in ('FORBIDDEN_CONTENT_DETECTED','DOUBTFUL') ) IRTZ_SS_OFF_ALL
       from
              results.results r
                        join portal.arrangements a on r.arrangement_id = a.id
         join sor.content_history ch on r.content_id=ch.content_id and r.start_date >=ch.st_dt and r.start_date<=ch.end_dt
         join sor.content_info ci on ch.content_id = ci.content_id and ch.content_version_id=ci.content_version_id
                   join config.robots on robots.name=a.access_tool
                  join dm.access_tool at on robots.orig_id=at.orig_id and a.creation_date>=at.eff_dttm and a.creation_date<at.end_dttm
and ((robots.type='PASD' and at.access_tool_tp_id=2))
         left join sor.addon on addon.content_id = ch.content_id and addon.addon_version_id=ch.addon_version_id
join dm.msr_prd on msr_prd.msr_prd_tp_id=? and r.end_date between msr_prd.eff_dttm and msr_prd.end_dttm
join (select distinct  on (r2.check_unit_value) r2.check_unit_value,r2.result from results.results r2 
join dm.msr_prd msr_prd2 on msr_prd2.msr_prd_tp_id=? and r2.end_date between msr_prd2.eff_dttm and msr_prd2.end_dttm
and msr_prd2.eff_dttm::date=?
order by check_unit_value,end_date desc nulls last ) last_r on r.check_unit_value=last_r.check_unit_value
where
msr_prd.eff_dttm::date=?
and access_tool_tp_id=2]]></xml-property>
