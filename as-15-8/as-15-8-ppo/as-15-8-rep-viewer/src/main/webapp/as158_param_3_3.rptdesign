        <oda-data-set extensionID="org.eclipse.birt.report.data.oda.jdbc.JdbcSelectDataSet" name="SSi_CAPTION" id="406">
            <property name="nullsOrdering">nulls lowest</property>
            <list-property name="columnHints">
                <structure>
                    <property name="columnName">caption</property>
                    <property name="analysis">dimension</property>
                    <text-property name="displayName">caption</text-property>
                    <text-property name="heading">caption</text-property>
                </structure>
            </list-property>
            <list-property name="parameters"/>
            <structure name="cachedMetaData">
                <list-property name="resultSet">
                    <structure>
                        <property name="position">1</property>
                        <property name="name">caption</property>
                        <property name="dataType">string</property>
                    </structure>
                </list-property>
            </structure>
            <property name="rowFetchLimit">1</property>
            <method name="beforeOpen"><![CDATA[queryStr=""
for (var index = 0; index < params["SSi"].value.length; index++) {
queryStr = queryStr.concat(params["SSi"].value[index] + ",");
}
queryStr = queryStr.substr(0, queryStr.length - 1);

this.queryText=this.queryText + " where  d.orig_id = ANY('{"+queryStr+"}'::bigint[])"
]]></method>
            <property name="dataSource">asdb</property>
            <list-property name="resultSet">
                <structure>
                    <property name="position">1</property>
                    <property name="name">caption</property>
                    <property name="nativeName">caption</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[with d as (select orig_id, label from (
(select orig_id, name as label,2  ord from sor.pasd where eff_dt='3000-01-01 00:00:00')
union
(select 0 orig_id,'Все ПАСД' as label,1 ord)) d order by ord, label)
select string_agg(label,', ') as caption  from d]]></xml-property>
            <xml-property name="designerValues"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
