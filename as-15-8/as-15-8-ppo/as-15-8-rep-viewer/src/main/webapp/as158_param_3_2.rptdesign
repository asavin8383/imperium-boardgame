            </structure>
            <property name="rowFetchLimit">1</property>
            <method name="beforeOpen"><![CDATA[queryStr=""
for (var index = 0; index < params["SSi"].value.length; index++) {
queryStr = queryStr.concat(params["SSi"].value[index] + ",");
}
queryStr = queryStr.substr(0, queryStr.length - 1);

this.queryText=this.queryText + " where  d.orig_id = ANY('{"+queryStr+"}'::bigint[])"
]]></method>
            <property name="dataSource">asdb</property>
            <list-property name="resultSet">
                <structure>
                    <property name="position">1</property>
                    <property name="name">caption</property>
                    <property name="nativeName">caption</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[with d as (select orig_id, label from (
(select orig_id, name as label,2  ord from sor.ps where eff_dt='3000-01-01 00:00:00')
union
(select 0 orig_id,'Все ПС' as label,1 ord)) d order by ord, label)
select string_agg(label,', ') as caption  from d]]></xml-property>
