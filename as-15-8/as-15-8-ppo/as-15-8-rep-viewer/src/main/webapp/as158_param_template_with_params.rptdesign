            </list-property>
            <xml-property name="queryText"><![CDATA[select orig_id, label from (
(select orig_id, name as label,2  ord from sor.ps where eff_dt='3000-01-01 00:00:00')
union
(select 0 orig_id,'Все ПС' as label,1 ord)) d order by ord, label]]></xml-property>
