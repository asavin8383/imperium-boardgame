            <property name="dataSource">Data Source</property>
            <list-property name="resultSet">
                <structure>
                    <property name="position">1</property>
                    <property name="name">num</property>
                    <property name="nativeName">num</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">2</property>
                    <property name="name">check_for_act</property>
                    <property name="nativeName">check_for_act</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">3</property>
                    <property name="name">check_unit_value</property>
                    <property name="nativeName">check_unit_value</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">4</property>
                    <property name="name">blocktype</property>
                    <property name="nativeName">blocktype</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">5</property>
                    <property name="name">end_date</property>
                    <property name="nativeName">end_date</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">6</property>
                    <property name="name">erdi_id</property>
                    <property name="nativeName">erdi_id</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">7</property>
                    <property name="name">screenshot_id</property>
                    <property name="nativeName">screenshot_id</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[select
row_number() OVER ()  AS num,
case when r.check_for_act then 'Да' else '' end check_for_act,
 r.check_unit_value, --ИРТЗ
       --r.result, -- Статус
        coalesce(ci.blocktype,'DEFAULT') as blocktype, -- Тип блокировки
       to_char (r.end_date,'DD.MM.YYYY HH24:MI:SS') as end_date, -- Дата и время проверки
              content.erdi_id as erdi_id,
       
        s.result_id as screenshot_id -- ID для формирования ссылки
 from
results.results r join sor.content_history ch on r.content_id=ch.content_id
and r.start_date >=ch.st_dt and r.start_date<ch.end_dt
join sor.content_info ci on ci.content_id=r.content_id and ci.content_version_id=ch.content_version_id
join sor.content on ch.content_id = content.id
left join results.result_screenshots  s on r.id = s.result_id
where r.arrangement_id=?
and coalesce(r.user_result,r.result) in (
--'COMPLETED',
'DOUBTFUL'
--,'FORBIDDEN_CONTENT_DETECTED','INTERNAL_ERROR'
    );]]></xml-property>
