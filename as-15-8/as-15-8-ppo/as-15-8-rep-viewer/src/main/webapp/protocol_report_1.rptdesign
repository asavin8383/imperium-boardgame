                </structure>
                <structure>
                    <property name="position">5</property>
                    <property name="name">screenshot_id</property>
                    <property name="nativeName">screenshot_id</property>
                    <property name="dataType">decimal</property>
                    <property name="nativeDataType">-5</property>
                </structure>
                <structure>
                    <property name="position">6</property>
                    <property name="name">error</property>
                    <property name="nativeName">error</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[select
row_number() OVER ()  AS num,
 r.check_unit_value, --ИРТЗ
       --r.result, -- Статус
        coalesce(ci.blocktype,'DEFAULT') as blocktype, -- Тип блокировки
       to_char (r.end_date,'DD.MM.YYYY HH24:MI:SS') as end_date, -- Дата и время проверки
       r.id as screenshot_id, -- ID для формирования ссылки
       error
 from
results.results r join sor.content_history ch on r.content_id=ch.content_id
and r.start_date >=ch.st_dt and r.start_date<ch.end_dt
join sor.content_info ci on ci.content_id=r.content_id and ci.content_version_id=ch.content_version_id
join results.result_screenshots  s on r.id = s.result_id
left outer join   results.error_detail_results d on r.id = d.result_id
where r.arrangement_id=?
and coalesce(r.user_result,r.result) in (
--'COMPLETED','DOUBTFUL','FORBIDDEN_CONTENT_DETECTED',
'INTERNAL_ERROR'
    );]]></xml-property>
