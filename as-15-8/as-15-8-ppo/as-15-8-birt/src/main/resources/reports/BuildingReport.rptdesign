            <xml-property name="queryText"><![CDATA[select zone_img.map_img                                                as zone_img,
       map_img.map_img                                                 as map_img,
       coalesce(current_image.preview, (select img from face.no_photo))    as current_image,
       coalesce(concept_image.preview, (select img from face.no_photo))    as concept_image,
       api.building_id,
       api.info->>'zone'                                               as zone,
       coalesce(api.info->>'comment',' ')                                            as comment,
       case      when coalesce(api.info->>'comment','-') != '-' then 'Дополнительная информация:' else '' end as comment_add,
       api.info->>'cn'                                                 as Кад_номер_строения,
       api.info->>'nm'                                                 as nm,
       api.info->> 'address'                                           as address,
       api.info-> 'info' -> 'sup_doc' ->> 'owner'                      as Собственность,
       api.info-> 'info' -> 'sup_doc' ->> 'register'                   as Запись_в_ЕГРН,
       api.info-> 'info' -> 'sup_doc' ->> 'area'                       as Площадь_объекта,
       api.info-> 'info' -> 'sup_doc' ->> 'floors'                     as Этажность,
       api.info-> 'info' -> 'sup_doc' ->> 'year'                       as Год_постройки,
       api.info-> 'info' -> 'sup_doc' ->> 'status'                     as Статус_объекта,
       api.info-> 'info' -> 'sup_doc' -> 'functions' ->> 'fact'        as Функциональное_фактическое_назначение,
       api.info-> 'info' -> 'sup_doc' -> 'functions' ->> 'plan'        as Функциональное_плановое_назначение,
       api.info-> 'info' -> 'sup_doc' ->> 'user'                       as Пользователь,
--info->'sup_doc' -> 'register' as register,
--info->'sup_doc' -> 'functions' -> 'plan' as plan,
       api.info-> 'info' -> 'sup_doc' ->> 'cad_area'                   as Кад_номер_ЗУ,
       api.info-> 'info' -> 'sup_doc' ->> 'usage_regulations'          as ПЗЗ_заявитель,
--info->'sup_doc' -> 'area'  -> 'functions' -> 'resp_staff' as resp_staff,
       api.info-> 'info' -> 'tech_doc' ->> 'works'                     as Состав_работ_по_реновации,
       api.info-> 'info' ->'tech_doc' -> 'fin_limits' ->> 'das_work'   as Лимит_финансирования_ПИР,
       api.info-> 'info' ->'tech_doc' -> 'fin_limits' ->> 'cai_work'   as Лимит_финансирования_СМР,
       api.info-> 'info' ->'tech_doc' -> 'fin_limits' ->> 'source'     as Источник,
       api.info-> 'info' ->'tech_doc' -> 'das_status'->> 'contrator'   as Статус_ПИР_Подрядчик,
       api.info-> 'info' ->'tech_doc' -> 'das_status'->> 'term'        as Статус_ПИР_Срок_по_договору,
       api.info-> 'info' ->'tech_doc' -> 'das_status'->> 'term_fact'   as Статус_ПИР_Факт_срок,
       api.info-> 'info' ->'tech_doc' -> 'cai_status'->> 'contrator'   as Статус_СМР_Подрядчик,
       api.info-> 'info' ->'tech_doc' -> 'cai_status'->> 'term'        as Статус_СМР_Срок_по_договору,
       api.info-> 'info' ->'tech_doc' -> 'cai_status'->> 'term_fact'   as Статус_СМР_Факт_срок,
       api.info-> 'info' ->'tech_doc' ->> 'compl_date'                 as Срок_завершения_реновации,
       api.info-> 'info' -> 'concept_doc'->>'planned_proj'             as Плановый_проект,
       api.info-> 'info' -> 'concept_doc'->>'proj_open_date'           as Дата_открытия_проекта,
       api.info-> 'info' -> 'service_doc'->'costs'->>'plan'            as Стоимость_ИТО_План_2019,
       api.info-> 'info' -> 'service_doc'->'costs'->> 'plan_rpa'       as Стоимость_ИТО_План_2019,
       api.info-> 'info' -> 'service_doc'->'costs' ->> 'fact'          as Стоимость_ИТО_Факт_2019,
       api.info-> 'info' -> 'gain'->'building_proceeds'->>'plan'       as Доходы_План_2019,
       api.info-> 'info' -> 'gain'->'building_proceeds' ->> 'plan_rpa' as Доходы_ставка_2019,
       api.info-> 'info' -> 'gain'->'building_proceeds' ->> 'fact'     as Доходы_Факт_2019
from sor.v_api_info_building api
       join (select t.rn, t.building_id
             from face.v_api_reports r,
                  json_array_elements(report -> 'report' -> 'building_ids') with ordinality as t (building_id, rn)
             where rep_id = ?) rd on api.building_id = rd.building_id :: text :: bigint
       join (select building_id, map_img
             from sor.zone_map_img_s s1,
                  sor.zone_x_building_l s2
             where s1.zone_id = s2.zone_id) zone_img on api.building_id = zone_img.building_id
       join (select building_id, map_img from sor.building_map_img_s) map_img on api.building_id = map_img.building_id
       left join (select building_id, preview
             from sor.building_x_photo_l
                    join sor.building_x_photo_s using (bxp_id)
                    join sor.photo_info_s using (photo_id)
             where is_cover is true
               and album_cd = 'album_current') current_image on api.building_id = current_image.building_id
        left join (select building_id, preview
             from sor.building_x_photo_l
                    join sor.building_x_photo_s using (bxp_id)
                    join sor.photo_info_s using (photo_id)
             where is_cover is true
               and album_cd = 'album_concept') concept_image on api.building_id = concept_image.building_id
order by rd.rn;]]></xml-property>
