            <xml-property name="queryText"><![CDATA[SELECT 
--nm,
--msr_prd_id,
--t1.ind_tp_id,
row_number() OVER ()  AS num,
 nm,
sum (mis_new) as mis_new,
sum (mis_all) as mis_all,
sum (mis_se) as mis_se,
sum (mis_s) as mis_s,
sum (mis_e) as mis_e,
sum (mis_t) as mis_t
--,ppn_dttm 
FROM dm.mis_at_stat_dm t1, dm.access_tool t2, dm.access_tool_tp t3, dm.msr_prd as msr_prd
where 
t1.msr_prd_id = msr_prd.msr_prd_id
and msr_prd.eff_dttm::date = ? and msr_prd.msr_prd_tp_id = ? and
t1.access_tool_id = t2.id
and t1.access_tool_tp_id = t3.access_tool_tp_id 
and t3.shrt_nm = 'ПАСД'
group by nm, t1.access_tool_id
order by t1.access_tool_id]]></xml-property>
        </oda-data-set>
    </data-sets>
