            <xml-property name="queryText"><![CDATA[SELECT 
--msr_prd.eff_dttm::date as dt ,
msr_prd.caption as dt ,
 nm::text as nm
 
FROM dm.msr_prd as msr_prd,
dm.msr_prd_tp as msr_prd_tp
where 
msr_prd.eff_dttm::date = ? and msr_prd.msr_prd_tp_id = ? and
msr_prd.msr_prd_tp_id = msr_prd_tp.msr_prd_tp_id 
]]></xml-property>
