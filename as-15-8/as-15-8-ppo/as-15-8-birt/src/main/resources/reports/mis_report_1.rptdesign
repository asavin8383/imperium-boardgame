                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT dsc,
--msr_prd_id,
--t1.ind_tp_id,
row_number() OVER ()  AS num,
sum (mis_new) as mis_new,
sum (mis_all) as mis_all,
sum (mis_se) as mis_se,
sum (mis_s) as mis_s,
sum (mis_e) as mis_e,
sum (mis_t) as mis_t
--,ppn_dttm 
FROM dm.mis_overall_stat_dm t1, dm.ind_tp t2, dm.msr_prd as msr_prd
where 
t1.msr_prd_id = msr_prd.msr_prd_id
and msr_prd.eff_dttm::date = ? and msr_prd.msr_prd_tp_id = ? and
t1.ind_tp_id = t2.ind_tp_id 
group by t2.dsc, t1.ind_tp_id
order by t1.ind_tp_id
]]></xml-property>
