<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd
    http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="rest.0002" author="asavin">
        <sql>insert into portal.access_tools_categories (id, name) values (0, 'DEFAULT')</sql>
        <addColumn tableName="access_tools" schemaName="portal">
            <column name="category_id" type="bigint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint
            baseTableSchemaName="portal"
            referencedTableSchemaName="portal"
            baseTableName="access_tools"
            baseColumnNames="category_id"
            constraintName="fk_access_tools_access_tools_categories"
            referencedTableName="access_tools_categories"
            referencedColumnNames="id"
            onUpdate="CASCADE"
            onDelete="CASCADE"/>
        <rollback>
            <sql>
                alter table portal.access_tools drop constraint fk_access_tools_access_tools_categories;
            </sql>
            <sql>
                delete from portal.access_tools_categories where id = 0;
            </sql>
            <dropColumn schemaName="portal" tableName="access_tools" columnName="category_id"/>
        </rollback>
    </changeSet>
</databaseChangeLog>