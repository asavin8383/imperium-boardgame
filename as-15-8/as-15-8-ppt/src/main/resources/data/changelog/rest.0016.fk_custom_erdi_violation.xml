                referencedTableSchemaName="sor"
                baseTableName="custom_erdi"
                baseColumnNames="violation_id"
                constraintName="fk_custom_erdi_violation"
                referencedTableName="violation"
                referencedColumnNames="id"
                onUpdate="CASCADE"
                onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>