    </changeSet>
    <changeSet author="pvorobiev" id="ppt.0006_2">
        <dropTable tableName="informal_tasks" schemaName="portal"/>
    </changeSet>
    <changeSet author="pvorobiev" id="ppt.0006_3">
        <addColumn schemaName="portal" tableName="formal_tasks">
            <column name="mission_id" type="bigint"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>