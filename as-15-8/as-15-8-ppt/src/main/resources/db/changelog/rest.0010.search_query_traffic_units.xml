<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd
    http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="rest.0010" author="asavin">
        <createTable tableName="search_query_traffic_units" schemaName="portal">
            <column name="traffic_unit_id" type="bigint" autoIncrement="false" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="query_pattern" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableSchemaName="portal"
                baseTableName="search_query_traffic_units"
                baseColumnNames="traffic_unit_id"
                constraintName="fk_erdi_traffic_units"
                referencedTableSchemaName="portal"
                referencedTableName="traffic_units"
                referencedColumnNames="id"
                onUpdate="CASCADE"
                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                baseTableSchemaName="portal"
                baseTableName="search_query_traffic_units"
                baseColumnNames="category_id"
                constraintName="fk_erdi_traffic_units_categories"
                referencedTableSchemaName="portal"
                referencedTableName="access_tools_categories"
                referencedColumnNames="id"
                onUpdate="CASCADE"
                onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>