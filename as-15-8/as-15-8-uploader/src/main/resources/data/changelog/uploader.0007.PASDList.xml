<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd
    http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">


    <changeSet id="uploader.0007" author="asin">
        <createTable tableName="PASDList" schemaName="sor">
            <column name="pasd_id" type="bigint" autoIncrement="true" >
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ppn_dt" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="eff_dt" type="timestamp">
                <constraints nullable="true"/>
            </column>
            <column name="orig_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="c_date" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="hostname" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="domainnames" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="servicedescription" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="networkaddresses" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="ipaccessfgis" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="credentials" type="varchar">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>